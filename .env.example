# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_APP_ID=1:123456789:android:abcdef
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Provider config
PROVIDER_PRIORITY=supabase,firebase
ACTIVE_PROVIDERS=supabase,firebase
SIMULTANEOUS_WRITES=true

# Google Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here

# Application Configuration
APP_VERSION=1.0.0
DEBUG_MODE=false

# Firebase Admin SDK Configuration
FIREBASE_ADMIN_SDK_TYPE=service_account
FIREBASE_ADMIN_SDK_PROJECT_ID=your_project_id_here
FIREBASE_ADMIN_SDK_CLIENT_EMAIL=firebase-adminsdk-fbsvc@your_project_id.iam.gserviceaccount.com
